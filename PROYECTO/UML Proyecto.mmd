classDiagram
direction LR

class BaseDeDatos {
  +string nombre
  +string tipo
  +conectar()
  +guardarDatos()
  +consultarDatos()
}

class Paciente {
  +int IdPaciente
  +string NombreCompleto
  +string Cedula
  +string Telefono
  +string Correo
  +bool Activo
}

class GestionPacientes {
  +agregarPaciente()
  +editarPaciente()
  +eliminarPaciente()
  +buscarPaciente()
  +listarPacientes()
}

class Cita {
  +int IdCita
  +int IdPaciente_FK
  +int IdMedico_FK
  +date Fecha
  +string Hora
  +string Estado
}

class Medico {
  +int IdMedico
  +string NombreCompleto
  +int IdEspecialidad_FK
}

class Especialidad {
  +int IdEspecialidad
  +string NombreEspecialidad
}

class HistorialMedico {
  +int IdHistorial
  +int IdPaciente_FK
  +string Diagnostico
  +string Tratamiento
  +date FechaRegistro
}

class Usuario {
  +int IdUsuario
  +string NombreUsuario
  +string Rol
}

class Ayuda {
  +mostrarInformacion()
  +contactoSoporte()
  +preguntasFrecuentes()
}

BaseDeDatos --> Paciente : guarda
BaseDeDatos --> Cita : almacena
BaseDeDatos --> HistorialMedico : registra

GestionPacientes --> Paciente : gestiona
GestionPacientes --> BaseDeDatos : usa

Paciente "1" --> "0..*" Cita : agenda
Medico "1" --> "0..*" Cita : atiende
Usuario "1" --> "0..*" Cita : gestiona

Medico --> Especialidad : pertenece
Paciente --> HistorialMedico : tiene

Ayuda --> Usuario : soporte