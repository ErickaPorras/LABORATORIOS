classDiagram
direction LR

class BaseDeDatos {
  +string nombre
  +string tipo
  +conectar()
  +guardarDatos()
  +consultarDatos()
}

class Paciente {
  +int IdPaciente
  +string NombreCompleto
  +string Cedula
  +string Telefono
  +string Correo
  +bool Activo
}

class GestionPacientes {
  +agregarPaciente()
  +editarPaciente()
  +eliminarPaciente()
  +buscarPaciente()
  +listarPacientes()
}

class Cita {
  +int IdCita
  +date Fecha
  +string Hora
  +string Estado
}

class Medico {
  +int IdMedico
  +string NombreCompleto
}

class Especialidad {
  +int IdEspecialidad
  +string NombreEspecialidad
}

class HistorialMedico {
  +int IdHistorial
  +string Diagnostico
  +string Tratamiento
  +date FechaRegistro
}

class Usuario {
  +int IdUsuario
  +string NombreUsuario
  +string Rol
}

class Ayuda {
  +mostrarInformacion()
  +contactoSoporte()
  +preguntasFrecuentes()
}

GestionPacientes --> Paciente : administra
GestionPacientes --> BaseDeDatos : usa

BaseDeDatos --> Paciente : almacena
BaseDeDatos --> Cita : almacena
BaseDeDatos --> HistorialMedico : almacena

Paciente "1" --> "0..*" Cita : agenda
Medico "1" --> "0..*" Cita : atiende
Usuario "1" --> "0..*" Cita : registra

Medico --> Especialidad : pertenece
Paciente "1" --> "0..*" HistorialMedico : posee

Cita --> Paciente : corresponde a
Cita --> Medico : asignado a

Ayuda --> Usuario : asiste
Ayuda --> GestionPacientes : guia
Ayuda --> Cita : ayuda